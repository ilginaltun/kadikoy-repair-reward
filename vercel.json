{
  "buildCommand": "mkdir -p public && cp index.html kadikoy_map_data.json *.png public/ 2>/dev/null || true",
  "outputDirectory": "public",
  "public": true,
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
